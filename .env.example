## Front-end (Vite, exposed in client bundle)

# Lead form proxy endpoint. Default: '/api/lead' (Cloudflare Pages Function).
# Set to empty string to force demo mode (no network call).
VITE_LEAD_API_URL=/api/lead

# Password for /admin route. Stored in sessionStorage on the client.
# Note: visible in the JS bundle — sufficient for personal stats protection,
# not suitable for sensitive data.
VITE_ADMIN_PASSWORD=change-me

## Server-side only (Cloudflare Pages → Settings → Environment variables)
## DO NOT prefix with VITE_ — these must NEVER reach the browser.

# Brevo Transactional API key (Settings → SMTP & API → API keys)
BREVO_API_KEY=xkeysib-your-key-here

# Email address that will receive lead form submissions
OWNER_EMAIL=loic@loicbarthoulot.ch

# Strict CORS allowlist for /api/lead (your deployed origin)
ALLOWED_ORIGIN=https://pc.loicbarthoulot.ch
